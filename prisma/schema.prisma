generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth adapter tables ───────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?

  accounts      Account[]
  sessions      Session[]
  memberships   OrganizationMembership[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id                    String   @id @default(uuid())
  sessionToken          String   @unique
  userId                String
  expires               DateTime
  currentOrganizationId String?

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Tenant ────────────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?

  memberships OrganizationMembership[]
  settings    OrganizationSettings?
  invites     Invite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("organizations")
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

model OrganizationMembership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           MemberRole

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectAssignments ProjectAssignment[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("organization_memberships")
}

model ProjectAssignment {
  id             String @id @default(uuid())
  organizationId String
  membershipId   String
  projectId      String

  membership OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  project    Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([membershipId, projectId])
  @@index([organizationId])
  @@index([projectId])
  @@map("project_assignments")
}

// ── Settings (Phase 10) ───────────────────────────────────────────────────────

model OrganizationSettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  // General
  description    String?      @db.Text
  timezone       String       @default("UTC")
  dateFormat     String       @default("DD/MM/YYYY")
  // Storage
  storageProvider String      @default("local")
  storageEndpoint String?
  storageAccessKey String?
  storageSecretKey String?
  storageBucket   String?
  // SMTP Email
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPassword    String?
  smtpFrom        String?
  smtpFromName    String?
  smtpSecure      Boolean     @default(true)
  // WhatsApp
  whatsappEnabled Boolean      @default(false)
  whatsappProvider String      @default("meta")
  whatsappPhoneNumberId String?
  whatsappBusinessAccountId String?
  whatsappAccessToken String?
  whatsappFromNumber String?
  // Notifications
  notifyEmail     Boolean     @default(true)
  notifyReminders Boolean     @default(true)
  notifyRaid      Boolean     @default(true)
  notifyDigest    Boolean     @default(false)
  // SSO / Identity Provider (Phase 12)
  ssoEnabled      Boolean     @default(false)
  ssoProtocol     String?     // "saml" or "oidc"
  ssoAutoProvision Boolean    @default(false)
  ssoDefaultRole  String      @default("member") // "admin", "member", "viewer"
  // SAML Settings
  samlEnabled     Boolean     @default(false)
  samlEntryPoint  String?     // IdP login URL
  samlIssuer      String?     // SP EntityID
  samlCertificate String?     @db.Text // IdP public certificate
  samlPrivateKey  String?     @db.Text // SP private key (for signing)
  samlNameIdFormat String?
  samlNameIdField String?     // SAML attribute for user ID
  samlEmailField  String?     // SAML attribute for email
  samlNameField   String?     // SAML attribute for name
  // OIDC Settings
  oidcEnabled     Boolean     @default(false)
  oidcClientId    String?
  oidcClientSecret String?    @db.Text
  oidcDiscoveryUrl String?    // Auto-discovery endpoint
  oidcIssuer      String?
  oidcAuthorizationUrl String?
  oidcTokenUrl    String?
  oidcUserinfoUrl String?
  oidcJwksUrl     String?
  oidcScope       String      @default("openid profile email") // Space-separated scopes
  // AI Suggestions
  aiEnabled              Boolean  @default(false)
  aiProvider             String   @default("anthropic")
  aiModel                String   @default("claude-sonnet-4-6")
  aiApiKey               String?  @db.Text
  aiDailyRefreshLimit    Int      @default(10)
  aiAnalyzeActivity      Boolean  @default(true)
  aiAnalyzeDeliverables  Boolean  @default(true)
  aiAnalyzeRaid          Boolean  @default(true)
  aiAnalyzeDecisions     Boolean  @default(true)
  aiAnalyzeNotes         Boolean  @default(true)

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("organization_settings")
}

// ── Invite System (Phase 11) ──────────────────────────────────────────────────

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

model Invite {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           MemberRole
  token          String       @unique @default(uuid())
  status         InviteStatus @default(pending)
  invitedBy      String       // actor name
  acceptedBy     String?      // user id if accepted
  sentAt         DateTime     @default(now())
  acceptedAt     DateTime?
  expiresAt      DateTime

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([email, organizationId])
  @@map("invites")
}

// ── Template Engine (Phase 2) ─────────────────────────────────────────────────

model Template {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  industry       String?
  version        String   @default("1.0")
  isArchived     Boolean  @default(false)

  focusAreas     FocusArea[]
  auditEvents    AuditEvent[]
  projects       Project[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("templates")
}

model FocusArea {
  id          String   @id @default(uuid())
  templateId  String
  code        String
  name        String
  order       Int      @default(0)

  template    Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subSections SubSection[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([templateId])
  @@map("focus_areas")
}

model SubSection {
  id          String   @id @default(uuid())
  focusAreaId String
  code        String
  name        String
  order       Int      @default(0)

  focusArea   FocusArea             @relation(fields: [focusAreaId], references: [id], onDelete: Cascade)
  deliverables DeliverableTemplate[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([focusAreaId])
  @@map("sub_sections")
}

model DeliverableTemplate {
  id                String   @id @default(uuid())
  subSectionId      String
  code              String
  name              String
  description       String?
  phase             String?
  domain            String?
  estimatedDuration Int?
  order             Int      @default(0)

  subSection          SubSection            @relation(fields: [subSectionId], references: [id], onDelete: Cascade)
  acceptanceCriteria  AcceptanceCriteria[]
  evidenceRequirements EvidenceRequirement[]
  dependencies        DeliverableTemplateDependency[] @relation("DependencySource")
  dependents          DeliverableTemplateDependency[] @relation("DependencyTarget")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subSectionId])
  @@map("deliverable_templates")
}

model AcceptanceCriteria {
  id                   String              @id @default(uuid())
  deliverableTemplateId String?
  deliverableExecutionId String?
  description          String
  verificationMethod   String?

  deliverableTemplate  DeliverableTemplate? @relation(fields: [deliverableTemplateId], references: [id], onDelete: Cascade)
  deliverableExecution DeliverableExecution? @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)
  completions          CriteriaCompletion[]

  @@index([deliverableTemplateId])
  @@index([deliverableExecutionId])
  @@map("acceptance_criteria")
}

model EvidenceRequirement {
  id                   String              @id @default(uuid())
  deliverableTemplateId String?
  deliverableExecutionId String?
  name                 String
  type                 String?
  description          String?
  required             Boolean             @default(true)

  deliverableTemplate  DeliverableTemplate? @relation(fields: [deliverableTemplateId], references: [id], onDelete: Cascade)
  deliverableExecution DeliverableExecution? @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)
  evidenceItems        Evidence[]

  @@index([deliverableTemplateId])
  @@index([deliverableExecutionId])
  @@map("evidence_requirements")
}

model DeliverableTemplateDependency {
  sourceId String
  targetId String

  source   DeliverableTemplate @relation("DependencySource", fields: [sourceId], references: [id], onDelete: Cascade)
  target   DeliverableTemplate @relation("DependencyTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@id([sourceId, targetId])
  @@map("deliverable_template_dependencies")
}

model AuditEvent {
  id                    String   @id @default(uuid())
  organizationId        String
  templateId            String?
  projectId             String?
  deliverableExecutionId String?
  actorName             String
  eventType             String
  description           String
  metadata              Json?

  template              Template?             @relation(fields: [templateId], references: [id], onDelete: SetNull)
  project               Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliverableExecution  DeliverableExecution? @relation(fields: [deliverableExecutionId], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())

  @@index([organizationId])
  @@index([templateId])
  @@index([projectId])
  @@index([deliverableExecutionId])
  @@map("audit_events")
}

// ── Phase 3: Projects & Deliverables ─────────────────────────────────────────

enum ProjectStatus {
  active
  blocked
  completed
  archived
}

model Project {
  id             String        @id @default(uuid())
  organizationId String
  templateId     String?
  name           String
  description    String?
  status         ProjectStatus @default(active)
  startDate      DateTime?
  targetDate     DateTime?

  template            Template?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  focusAreaExecutions FocusAreaExecution[]
  auditEvents         AuditEvent[]
  raidItems           RAIDItem[]
  decisions           Decision[]
  reports             Report[]
  assignments         ProjectAssignment[]
  notificationSettings ProjectNotificationSettings?
  notificationMessages ProjectNotificationMessage[]
  aiSuggestions       AISuggestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("projects")
}

model ProjectNotificationSettings {
  id              String   @id @default(uuid())
  projectId       String   @unique
  organizationId  String
  notifyEmail     Boolean  @default(true)
  notifyReminders Boolean  @default(true)
  notifyRaid      Boolean  @default(true)
  notifyDigest    Boolean  @default(false)

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId])
  @@map("project_notification_settings")
}

enum ProjectNotificationChannel {
  email
  whatsapp
}

enum ProjectNotificationStatus {
  sent
  dismissed
}

model ProjectNotificationMessage {
  id             String                     @id @default(uuid())
  organizationId String
  projectId      String
  generatedKey   String
  kind           String
  channel        ProjectNotificationChannel
  status         ProjectNotificationStatus
  recipientType  String
  recipientId    String?
  recipientName  String
  recipientEmail String?
  recipientPhone String?
  subject        String
  body           String                     @db.Text
  sentAt         DateTime?
  dismissedAt    DateTime?

  project        Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@unique([projectId, generatedKey, channel, recipientType, recipientId])
  @@index([organizationId])
  @@index([projectId])
  @@map("project_notification_messages")
}

model FocusAreaExecution {
  id        String @id @default(uuid())
  projectId String
  code      String
  name      String
  order     Int    @default(0)

  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subSections SubSectionExecution[]

  @@index([projectId])
  @@map("focus_area_executions")
}

model SubSectionExecution {
  id                 String @id @default(uuid())
  focusAreaExecutionId String
  code               String
  name               String
  order              Int    @default(0)

  focusAreaExecution FocusAreaExecution     @relation(fields: [focusAreaExecutionId], references: [id], onDelete: Cascade)
  deliverables       DeliverableExecution[]

  @@index([focusAreaExecutionId])
  @@map("sub_section_executions")
}

enum DeliverableStatus {
  planned
  in_progress
  delayed
  closed
}

model DeliverableExecution {
  id                    String            @id @default(uuid())
  organizationId        String
  subSectionExecutionId String
  templateDeliverableId String?

  name        String
  code        String
  description String?
  status      DeliverableStatus @default(planned)
  phase       String?
  domain      String?

  startDate  DateTime?
  targetDate DateTime?
  closedAt   DateTime?
  notes      String?   @db.Text
  progress   Int       @default(0)
  priority   String    @default("medium")

  subSectionExecution SubSectionExecution  @relation(fields: [subSectionExecutionId], references: [id], onDelete: Cascade)
  auditEvents         AuditEvent[]
  raidLinks           RAIDItemDeliverable[]
  peopleLinks         DeliverableExecutionPerson[]
  vendorLinks         DeliverableExecutionVendor[]
  owner               Person?              @relation("DeliverableOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId             String?
  evidenceItems       Evidence[]
  evidenceRequirements EvidenceRequirement[]
  acceptanceCriteria  AcceptanceCriteria[]
  criteriaCompletions CriteriaCompletion[]
  deliverableNotes    DeliverableNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([subSectionExecutionId])
  @@map("deliverable_executions")
}

// ── Phase 4: RAID Log ─────────────────────────────────────────────────────────

enum RAIDType {
  risk
  assumption
  issue
  dependency
}

enum RAIDSeverity {
  low
  medium
  high
  critical
}

enum RAIDLikelihood {
  rare
  unlikely
  possible
  likely
  almost_certain
}

enum RAIDStatus {
  open
  in_progress
  closed
}

model RAIDItem {
  id             String        @id @default(uuid())
  organizationId String
  projectId      String
  type           RAIDType
  title          String
  description    String?
  severity       RAIDSeverity  @default(medium)
  likelihood     RAIDLikelihood?
  status         RAIDStatus    @default(open)
  owner          String?
  dueDate        DateTime?
  mitigationPlan String?       @db.Text
  closedAt       DateTime?

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables   RAIDItemDeliverable[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("raid_items")
}

model RAIDItemDeliverable {
  raidItemId           String
  deliverableExecutionId String

  raidItem             RAIDItem             @relation(fields: [raidItemId], references: [id], onDelete: Cascade)
  deliverableExecution DeliverableExecution @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)

  @@id([raidItemId, deliverableExecutionId])
  @@map("raid_item_deliverables")
}

// ── Phase 5: Stakeholders & Team ──────────────────────────────────────────────

enum PersonType {
  internal
  contractor
  consultant
}

enum PersonRole {
  owner
  team
  end_user
}

model Person {
  id             String     @id @default(uuid())
  organizationId String
  name           String
  type           PersonType @default(internal)
  company        String?
  role           PersonRole @default(team)
  email          String?
  phone          String?
  notes          String?    @db.Text

  deliverableLinks DeliverableExecutionPerson[]
  ownedDeliverables DeliverableExecution[]      @relation("DeliverableOwner")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("people")
}

enum VendorType {
  supplier
  service_provider
}

model Vendor {
  id             String     @id @default(uuid())
  organizationId String
  name           String
  type           VendorType @default(supplier)
  contactName    String?
  contactRole    String?
  email          String?
  phone          String?
  address        String?
  website        String?
  notes          String?    @db.Text

  deliverableLinks DeliverableExecutionVendor[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("vendors")
}

model DeliverableExecutionPerson {
  deliverableExecutionId String
  personId               String

  deliverableExecution   DeliverableExecution @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)
  person                 Person               @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([deliverableExecutionId, personId])
  @@map("deliverable_execution_people")
}

model DeliverableExecutionVendor {
  deliverableExecutionId String
  vendorId               String

  deliverableExecution   DeliverableExecution @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)
  vendor                 Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@id([deliverableExecutionId, vendorId])
  @@map("deliverable_execution_vendors")
}

// ── Phase 6: Evidence & Acceptance Criteria ───────────────────────────────────

enum EvidenceType {
  document
  image
  link
  sign_off
}

model Evidence {
  id                     String              @id @default(uuid())
  organizationId         String
  deliverableExecutionId String
  evidenceRequirementId  String?

  name         String
  type         EvidenceType
  url          String
  fileSize     Int?

  uploadedBy   String
  uploadedAt   DateTime            @default(now())

  verified     Boolean             @default(false)
  verifiedAt   DateTime?
  verifiedBy   String?

  deliverableExecution  DeliverableExecution @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)
  evidenceRequirement   EvidenceRequirement? @relation(fields: [evidenceRequirementId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([deliverableExecutionId])
  @@map("evidence")
}

model CriteriaCompletion {
  id                     String @id @default(uuid())
  organizationId         String
  deliverableExecutionId String
  acceptanceCriteriaId   String

  completed    Boolean   @default(false)
  completedAt  DateTime?
  completedBy  String?
  notes        String?

  deliverableExecution DeliverableExecution @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)
  acceptanceCriteria   AcceptanceCriteria   @relation(fields: [acceptanceCriteriaId], references: [id], onDelete: Cascade)

  @@unique([deliverableExecutionId, acceptanceCriteriaId])
  @@index([deliverableExecutionId])
  @@map("criteria_completions")
}

// ── Phase 7: Notes & Decisions ────────────────────────────────────────────────

model DeliverableNote {
  id                     String   @id @default(uuid())
  organizationId         String
  deliverableExecutionId String
  text                   String   @db.Text
  authorName             String

  deliverableExecution DeliverableExecution @relation(fields: [deliverableExecutionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([deliverableExecutionId])
  @@map("deliverable_notes")
}

enum DecisionStatus {
  pending
  approved
  rejected
  deferred
}

model Decision {
  id             String         @id @default(uuid())
  organizationId String
  projectId      String
  description    String         @db.Text
  impact         String?        @db.Text
  loggedDate     DateTime       @default(now())
  status         DecisionStatus @default(pending)
  comments       String?        @db.Text
  loggedBy       String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("decisions")
}

// ── Phase 9: Reports & Sharing ────────────────────────────────────────────────

enum ReportType {
  detailed_activities
  executive_summary
}

enum ReportStatus {
  draft
  published
}

model Report {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  title          String
  reportType     ReportType
  status         ReportStatus @default(draft)
  shareToken     String?      @unique @default(uuid())
  createdBy      String
  periodStart    DateTime?
  periodEnd      DateTime?
  publishedAt    DateTime?

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sections       ReportSection[]
  accessLog      ReportAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([shareToken])
  @@map("reports")
}

model ReportSection {
  id        String @id @default(uuid())
  reportId  String
  type      String
  title     String
  content   Json
  comment   String? @db.Text
  sortOrder Int     @default(0)

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@map("report_sections")
}

model ReportAccess {
  id         String   @id @default(uuid())
  reportId   String
  accessedAt DateTime @default(now())
  accessedBy String?
  ipAddress  String?
  userAgent  String?

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_access")
}

// ── AI Suggestions ────────────────────────────────────────────────────────────

model AISuggestion {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  model          String
  promptVersion  String   @default("1")

  items          AISuggestionItem[]
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([projectId])
  @@map("ai_suggestions")
}

model AISuggestionItem {
  id             String   @id @default(uuid())
  suggestionId   String
  type           String   // 'risk' | 'action' | 'insight'
  priority       String   // 'high' | 'medium' | 'low'
  title          String
  description    String   @db.Text
  actionType     String?  // 'send_reminder' | 'request_evidence' | 'create_raid'
  actionPayload  Json?
  dismissed      Boolean  @default(false)
  executedAt     DateTime?
  executedBy     String?

  suggestion     AISuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@index([suggestionId])
  @@map("ai_suggestion_items")
}

model AIRefreshLog {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  date           String   // YYYY-MM-DD
  count          Int      @default(0)

  @@unique([projectId, date])
  @@index([organizationId])
  @@map("ai_refresh_logs")
}
